<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutNoConnection"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:visibility="visible">

    <ImageView
        android:id="@+id/ivEmptyState"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/icon_heart" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Chưa có kết nối nào"
        android:textColor="#888888"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Hãy kết nối với người thương để cùng chia sẻ và lưu giữ những khoảnh khắc đáng nhớ nhé!"
        android:textAlignment="center"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnConnectPartner"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#FF5864"
        android:text="+ Kết nối đối phương"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp" />

</LinearLayout>