<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F5"> <RelativeLayout
    android:id="@+id/rlHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    app:layout_constraintTop_toTopOf="parent">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FF5864" />

    <TextView
        android:id="@+id/txtHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="💖 Kết nối với đối phương"
        android:textColor="#333333"
        android:textSize="20sp"
        android:textStyle="bold" />
</RelativeLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clAvatars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/rlHeader">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvMyAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="4dp"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/ivHeart"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/ivMyAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/default_avatar" />
        </androidx.cardview.widget.CardView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn"
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/cvMyAvatar"
            app:layout_constraintLeft_toLeftOf="@id/cvMyAvatar"
            app:layout_constraintRight_toRightOf="@id/cvMyAvatar"/>

        <ImageView
            android:id="@+id/ivHeart"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/icon_heart"
            app:layout_constraintBottom_toBottomOf="@+id/cvMyAvatar"
            app:layout_constraintLeft_toRightOf="@+id/cvMyAvatar"
            app:layout_constraintRight_toLeftOf="@+id/cvPartnerAvatar"
            app:layout_constraintTop_toTopOf="@+id/cvMyAvatar" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cvPartnerAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="4dp"
            app:layout_constraintLeft_toRightOf="@+id/ivHeart"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/ivPartnerAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/default_avatar" />
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/txtPartnerNameHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chờ người kia..."
            android:textColor="#555555"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/cvPartnerAvatar"
            app:layout_constraintLeft_toLeftOf="@id/cvPartnerAvatar"
            app:layout_constraintRight_toRightOf="@id/cvPartnerAvatar"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_info_card"
        android:elevation="10dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clAvatars">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Chỉ cần gọi 2 dòng include này -->
            <include
                android:id="@+id/layoutNoConnection"
                layout="@layout/layout_no_connection" />
            <include
                android:id="@+id/layoutConnected"
                layout="@layout/layout_connected" />

        </FrameLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>