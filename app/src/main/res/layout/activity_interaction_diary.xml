<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F5"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FF5864" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="NHẬT KÝ TƯƠNG TÁC"
            android:textStyle="bold"
            android:textColor="#333333"/>
    </RelativeLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clAvatars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/rlHeader">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvMyAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="4dp"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/ivHeart"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/ivMyAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/default_avatar" />
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/txtMyNameHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn"
            android:textColor="#555555"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/cvMyAvatar"
            app:layout_constraintLeft_toLeftOf="@id/cvMyAvatar"
            app:layout_constraintRight_toRightOf="@id/cvMyAvatar"/>

        <ImageView
            android:id="@+id/ivHeart"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/icon_heart"
            app:tint="#FF5864"
            app:layout_constraintBottom_toBottomOf="@+id/cvMyAvatar"
            app:layout_constraintLeft_toRightOf="@+id/cvMyAvatar"
            app:layout_constraintRight_toLeftOf="@+id/cvPartnerAvatar"
            app:layout_constraintTop_toTopOf="@+id/cvMyAvatar" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cvPartnerAvatar"
            android:layout_width="90dp"
            android:layout_height="90dp"
            app:cardCornerRadius="45dp"
            app:cardElevation="4dp"
            app:layout_constraintLeft_toRightOf="@+id/ivHeart"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/ivPartnerAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/default_avatar" />
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/txtPartnerNameHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chờ người kia..."
            android:textColor="#555555"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/cvPartnerAvatar"
            app:layout_constraintLeft_toLeftOf="@id/cvPartnerAvatar"
            app:layout_constraintRight_toRightOf="@id/cvPartnerAvatar"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFF5F5"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtConnectedDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#FF5864"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày đã kết nối"
                    android:textColor="#666666"
                    android:textSize="14sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#F5F9FF"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtChatStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#4A90E2"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chuỗi ngày nhắn tin (Streak)"
                    android:textColor="#666666"
                    android:textSize="14sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</LinearLayout>